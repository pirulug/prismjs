{
  "name": "prismjs",
  "version": "0.0.12",
  "description": "Custom PrismJS build with toolbar and enhancements",
  "main": "dist/js/prism.js",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production --progress",
    "dev": "webpack --config webpack.config.js --mode development --progress",
    "start": "webpack serve --config webpack.config.js --mode development --progress",
    "watch": "webpack --config webpack.config.js --mode development --watch --progress"
  },
